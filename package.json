{
	"name": "linguist-map",
	"version": "0.0.1",
	"description": "Linguist languages.yml data",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./data/*": {
			"require": "./dist/data/*.cjs",

			"types": "./dist/data/*.d.ts",
			"import": "./dist/data/*.js"
		},
		"./getters": {
			"require": "./dist/getters/index.cjs",

			"types": "./dist/getters/index.d.ts",
			"import": "./dist/getters/index.js"
		},
		"./*": {
			"require": "./dist/types/*.cjs",

			"types": "./dist/types/*.d.ts",
			"import": "./dist/types/*.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"build": "pnpm run generate && tsup",
		"dev": "tsup --watch",
		"generate": "tsx ./src/entry/entry.ts",
		"lint": "biome check --write"
	},
	"keywords": [
		"linguist",
		"languages",
		"language-data",
		"language-metadata",
		"extension"
	],
	"author": {
		"name": "2qp",
		"url": "https://github.com/2qp"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/2qp/linguist-map.git"
	},
	"bugs": {
		"url": "https://github.com/2qp/linguist-map/issues"
	},
	"license": "ISC",
	"packageManager": "pnpm@10.24.0",
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.0.1",
		"glob": "^13.0.0",
		"js-yaml": "^4.1.1",
		"safe-stable-stringify": "^2.5.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
