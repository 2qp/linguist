{
	"name": "linguist-map",
	"version": "0.0.0",
	"description": "Linguist `languages.yml` data",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./*": {
			"import": {
				"types": "./dist/data/*.d.ts",
				"default": "./dist/data/*.js"
			},
			"require": {
				"types": "./dist/data/*.d.cts",
				"default": "./dist/data/*.cjs"
			}
		},
		"./getters": {
			"import": {
				"types": "./dist/getters/index.d.ts",
				"default": "./dist/getters/index.js"
			},
			"require": {
				"types": "./dist/getters/index.d.cts",
				"default": "./dist/getters/index.cjs"
			}
		},
		"./predicates": {
			"import": {
				"types": "./dist/predicates/index.d.ts",
				"default": "./dist/predicates/index.js"
			},
			"require": {
				"types": "./dist/predicates/index.d.cts",
				"default": "./dist/predicates/index.cjs"
			}
		},
		".": {
			"import": {
				"types": "./dist/types/common/index.d.ts",
				"default": "./dist/types/common/index.js"
			},
			"require": {
				"types": "./dist/types/common/index.d.cts",
				"default": "./dist/types/common/index.cjs"
			}
		},
		"./usage": {
			"import": {
				"types": "./dist/types/usage/index.d.ts",
				"default": "./dist/types/usage/index.js"
			},
			"require": {
				"types": "./dist/types/usage/index.d.cts",
				"default": "./dist/types/usage/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "vitest --typecheck",
		"clean": "rimraf dist src/generated",
		"build": "pnpm run clean && pnpm run generate && tsup",
		"dev": "tsup --watch",
		"generate": "rimraf src/generated && tsx ./src/entry/entry.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write",
		"test:upstream:guard": "vitest upstream.guard.test --run",
		"test:core": "vitest --exclude=\"**/generated.test.ts\" --exclude=\"**/upstream.guard.test.ts\" --exclude=\"**/*.integrity.test.ts\" --run --typecheck",
		"test:generated": "vitest generated --run --typecheck",
		"on:guard:pass": "tsx ./src/scripts/on-guard-pass.ts",
		"guard:generate": "pnpm run typecheck && pnpm run test:upstream:guard && pnpm run on:guard:pass && pnpm run generate",
		"generate:build": "pnpm typecheck && pnpm test:upstream:guard && pnpm on:guard:pass && pnpm build",
		"act:simulate": "act --artifact-server-path /tmp/artifacts --secret-file .secrets",
		"docs:meta:tables": "tsx ./src/scripts/create-meta-tables.ts"
	},
	"keywords": [
		"linguist",
		"languages",
		"language-data",
		"language-metadata",
		"extension"
	],
	"author": {
		"name": "2qp",
		"url": "https://github.com/2qp"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/2qp/linguist-map.git"
	},
	"bugs": {
		"url": "https://github.com/2qp/linguist-map/issues"
	},
	"license": "MIT",
	"packageManager": "pnpm@10.24.0",
	"devDependencies": {
		"@babel/parser": "^7.29.2",
		"@babel/types": "^7.29.0",
		"@biomejs/biome": "^2.4.13",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "7.0.0-dev.20260426.1",
		"glob": "^13.0.6",
		"js-yaml": "^4.1.1",
		"rimraf": "^6.1.3",
		"safe-stable-stringify": "^2.5.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.5"
	}
}
