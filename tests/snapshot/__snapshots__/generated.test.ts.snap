// Type-safe accessors
export type GetLanguage<Name extends LanguageName> = Languages[Name];
export type GetLanguageField<Name extends LanguageName, Field extends LanguageField> = Languages[Name][Field];
export type GetLanguagesByType<Type extends (Language['type'] extends infer T ? T : never)> = {
[K in LanguageName as Languages[K]['type'] extends Type ? K : never]: Languages[K];
};

