// Utility types
export type Languages = Record<LanguageName, Language>;
export type LanguageField = keyof Language;

export /**
 * dictionary type that accepts any string key.
 *
 * useful as a fallback type for objects with unknown or dynamic keys.
 *
 * evolved from \`FallbackForUnknownKeys\`.
 *
 * @example
 * type Config = {
 *   knownSetting: string;
 * } & Dictionary<unknown>;
 */
type Dictionary<T> = Record<string & {}, T>;

